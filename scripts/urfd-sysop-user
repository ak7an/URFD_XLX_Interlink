#!/usr/bin/env bash
set -euo pipefail

HTPASSWD_FILE="/etc/apache2/.htpasswd-urfd-sysop"

usage() {
    cat <<EOF
Usage:
  sudo urfd-sysop-user add USERNAME
  sudo urfd-sysop-user remove USERNAME
  sudo urfd-sysop-user list

Examples:
  sudo urfd-sysop-user add Admin2
  sudo urfd-sysop-user remove Admin2
  sudo urfd-sysop-user list
EOF
}

if [ "$EUID" -ne 0 ]; then
    echo "[FAIL] Please run as root"
    echo
    usage
    exit 1
fi

ACTION="${1:-}"
USER_NAME="${2:-}"

case "$ACTION" in
    add)
        if [ -z "$USER_NAME" ]; then
            echo "[FAIL] Username required"
            usage
            exit 1
        fi

        install -d -m 755 /etc/apache2

        if [ ! -f "$HTPASSWD_FILE" ]; then
            htpasswd -c "$HTPASSWD_FILE" "$USER_NAME"
        else
            htpasswd "$HTPASSWD_FILE" "$USER_NAME"
        fi

        chmod 640 "$HTPASSWD_FILE"
        chown root:www-data "$HTPASSWD_FILE"

        echo "[PASS] Sysop user added/updated: $USER_NAME"
        ;;

    remove|delete)
        if [ -z "$USER_NAME" ]; then
            echo "[FAIL] Username required"
            usage
            exit 1
        fi

        if [ ! -f "$HTPASSWD_FILE" ]; then
            echo "[FAIL] Sysop password file missing: $HTPASSWD_FILE"
            exit 1
        fi

        htpasswd -D "$HTPASSWD_FILE" "$USER_NAME"

        echo "[PASS] Sysop user removed: $USER_NAME"
        ;;

    list)
        if [ ! -f "$HTPASSWD_FILE" ]; then
            echo "[WARN] No sysop users configured"
            exit 0
        fi

        echo "Configured sysop users:"
        cut -d: -f1 "$HTPASSWD_FILE"
        ;;

    help|-h|--help|"")
        usage
        ;;

    *)
        echo "[FAIL] Unknown action: $ACTION"
        echo
        usage
        exit 1
        ;;
esac
