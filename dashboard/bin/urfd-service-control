#!/bin/sh
set -eu

ACTION="${1:-}"
SERVICE="${2:-}"
CONF="/etc/urfd-dashboard/service-controls.conf"

control_unit() {
    ACTION="$1"
    UNIT="$2"

    case "$UNIT" in
        *.service)
            ;;
        *)
            echo "Invalid service unit" >&2
            exit 1
            ;;
    esac

    case "$ACTION" in
        start|stop|restart)
            ;;
        *)
            echo "Invalid action" >&2
            exit 1
            ;;
    esac

    exec /bin/systemctl "$ACTION" "$UNIT"
}

case "$SERVICE" in
    urfd-tcd)
        control_unit "$ACTION" "urfd-tcd.service"
        ;;
esac

if [ -r "$CONF" ]; then
    if awk -F= '
        /^[[:space:]]*#/ { next }
        /^[[:space:]]*$/ { next }
        /^[[:space:]]*service[[:space:]]*=/ {
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
            if ($2 == target) found=1
        }
        END { exit found ? 0 : 1 }
    ' target="$SERVICE" "$CONF"; then
        control_unit "$ACTION" "$SERVICE"
    fi
fi

echo "Invalid service" >&2
exit 1
